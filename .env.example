# Environment variables for the IEEE Quantum Week 2026 TD-TSP benchmark.
# Copy this file to `.env` and fill in the values for the backends you plan
# to run. None of the values below are required for inspecting the frozen
# instance JSONs in data/instances/ or the published result JSONs in
# results/; they are only needed when re-running the benchmark drivers in
# code/refined/benchmarks/.

# -----------------------------------------------------------------------------
# Gurobi (classical MILP baseline + autonomous reference)
# -----------------------------------------------------------------------------
# Gurobi resolves licensing automatically when a `gurobi.lic` file is present
# in your home directory or the working directory. Place your license file
# there; nothing needs to be set in this file.

# -----------------------------------------------------------------------------
# D-Wave (Leap Hybrid CQM)
# -----------------------------------------------------------------------------
# Personal access token from https://cloud.dwavesys.com/leap/
DWAVE_API_TOKEN=

# -----------------------------------------------------------------------------
# AWS Braket (SV1 simulator + Rigetti Cepheus QPU)
# -----------------------------------------------------------------------------
# IAM user keys with AmazonBraketFullAccess (or a scoped equivalent that grants
# braket:CreateQuantumTask, braket:GetQuantumTask, and PutObject on the S3
# bucket(s) below).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Default region for SV1 (us-east-1 is fine).
AWS_DEFAULT_REGION=us-east-1

# Optional explicit S3 destination for Braket task results. If unset, the
# Braket SDK falls back to the default account-level bucket.
# For Rigetti Cepheus the bucket MUST live in us-west-1; for SV1 use a bucket
# in us-east-1.
BRAKET_S3_BUCKET=
BRAKET_S3_BUCKET_RIGETTI=
BRAKET_S3_PREFIX=tasks

# -----------------------------------------------------------------------------
# Quanfluence (Ising machine, REST API)
# -----------------------------------------------------------------------------
QUANFLUENCE_BASE_URL=https://gateway.quanfluence.com
QUANFLUENCE_USERNAME=
QUANFLUENCE_PASSWORD=
QUANFLUENCE_DEVICE_ID=41
